  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "cdae8b5d-7d61-4cec-9681-39e41749b9c5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def merge_fasta_files(file_list, output_file):\n",
    "    with open(output_file, 'w') as outfile:\n",
    "        for fasta_file in file_list:\n",
    "            with open(fasta_file, 'r') as infile:\n",
    "                outfile.write(infile.read())\n",
    "\n",
    "# Example usage\n",
    "fasta_files = ['Segment6_H1N1.fasta', 'Segment6_H5N1.fasta','H3N2 seg6 output.fasta','H7N9-seg6.fasta','adenovirus.fasta','PRCV.fasta']\n",
    "output_file = 'merged_output_NA.fasta'\n",
    "merge_fasta_files(fasta_files, output_file)\n"
   ]
  },
