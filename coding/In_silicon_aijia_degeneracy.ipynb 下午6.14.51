    "import re\n",
    "\n",
    "# Function to convert a degenerate primer sequence into a regex pattern\n",
    "def expand_degenerate_primer(primer):\n",
    "    \"\"\" Convert degenerate bases in a primer sequence to a regex pattern. \"\"\"\n",
    "    base_mapping = {\n",
    "        'A': 'A', 'T': 'T', 'G': 'G', 'C': 'C',\n",
    "        'R': '[AG]', 'Y': '[CT]', 'S': '[GC]',\n",
    "        'W': '[AT]', 'K': '[GT]', 'M': '[AC]',\n",
    "        'B': '[CGT]', 'D': '[AGT]', 'H': '[ACT]',\n",
    "        'V': '[ACG]', 'N': '[ATGC]'  # 'N' matches any base\n",
    "    }\n",
    "    \n",
    "    # Build a regex pattern by replacing each base with its expanded form\n",
    "    regex_pattern = ''.join(base_mapping.get(base, base) for base in primer)\n",
    "    return regex_pattern\n",
    "\n",
    "# Function to check if any expanded primers are found in the FASTA sequences\n",
    "def do_primers_work(FP):\n",
    "    variant_qPCR_results = {}\n",
    "    \n",
    "    # Iterate over the sequences in the FASTA dictionary\n",
    "    for seq_key, sequence in FASTA_dict.items():\n",
    "        variant_qPCR_results[seq_key] = []\n",
    "        found = False\n",
    "        \n",
    "        # Check each primer in the list\n",
    "        for target_seq1 in FP:\n",
    "            # Convert the degenerate primer to a regex pattern\n",
    "            expanded_primer_pattern = expand_degenerate_primer(target_seq1)\n",
    "            \n",
    "            # Search for the regex pattern in the sequence\n",
    "            if re.search(expanded_primer_pattern, sequence):\n",
    "                found = True\n",
    "                break\n",
    "        \n",
    "        # Record whether the primer was found in the sequence\n",
    "        variant_qPCR_results[seq_key].append(found)\n",
    "    \n",
    "    return variant_qPCR_results\n",
    "\n",
    "# Function to load a FASTA file and store sequences in a dictionary\n",
    "def load_fasta(filename):\n",
    "    FASTA_dict = {}\n",
    "    with open(filename, 'r') as f:\n",
    "        seq_name = None\n",
    "        seq = ''\n",
    "        for line in f:\n",
    "            if line.startswith('>'):\n",
    "                if seq_name is not None:\n",
    "                    FASTA_dict[seq_name] = seq\n",
    "                seq_name = line.lstrip('>').rstrip('\\n')\n",
    "                seq = ''\n",
    "            else:\n",
    "                seq += line.rstrip('\\n')\n",
    "        # Add last sequence after loop\n",
    "        if seq_name is not None:\n",
    "            FASTA_dict[seq_name] = seq\n",
    "    return FASTA_dict\n",
    "\n",
    "# Example: Load the FASTA file\n",
    "FASTA_file_1 = 'Segment4_H5N1.fasta'\n",
    "FASTA_dict = load_fasta(FASTA_file_1)\n",
    "\n",
    "# Example FP list with a degenerate primer\n",
    "FP = ['GTATGCCATTCCACAAC']\n",
    "\n",
    "# Initialize the original variant and results\n",
    "original_variant = FP[0]\n",
    "print(f\"Running for original variant: {original_variant}\")\n",
    "result = do_primers_work([original_variant])\n",
    "\n",
    "# Count the True and False results for the original variant\n",
    "T = sum(1 for values in result.values() if values[0])\n",
    "F = sum(1 for values in result.values() if not values[0])\n",
    "\n",
    "# Calculate and print sensitivity for the original variant\n",
    "sensitivity = T / (T + F) if T + F > 0 else \"N/A\"\n",
    "print(f\"Sensitivity for {original_variant}: {sensitivity}\")\n",
    "print(f\"Number of sequences with the primer present (True): {T}\")\n",
    "print(f\"Number of sequences without the primer (False): {F}\")\n",
    "print(\"--------------------\")\n",
    "\n",
    "# Initialize variables to track the best modified variant\n",
    "highest_sensitivity = 0\n",
    "best_variant = original_variant\n",
    "\n",
    "# Now test replacing each base position with \"N\"\n",
    "for i in range(len(original_variant)):\n",
    "    # Replace the base at position i with \"N\" and keep the rest the same\n",
    "    if original_variant[i] != 'N':  # Only replace if it's not already 'N'\n",
    "        modified_variant = original_variant[:i] + 'N' + original_variant[i+1:]\n",
    "        print(f\"Running for modified variant: {modified_variant}\")\n",
    "        result = do_primers_work([modified_variant])\n",
    "        \n",
    "        # Count the True and False results\n",
    "        T = sum(1 for values in result.values() if values[0])\n",
    "        F = sum(1 for values in result.values() if not values[0])\n",
    "        \n",
    "        # Calculate sensitivity for the modified variant\n",
    "        sensitivity = T / (T + F) if T + F > 0 else \"N/A\"\n",
    "        \n",
    "        print(f\"Sensitivity for {modified_variant}: {sensitivity}\")\n",
    "        print(f\"Number of sequences with the primer present (True): {T}\")\n",
    "        print(f\"Number of sequences without the primer (False): {F}\")\n",
    "        print(\"--------------------\")\n",
    "        \n",
    "        # Update the best variant if the current one has higher sensitivity\n",
    "        if isinstance(sensitivity, float) and sensitivity > highest_sensitivity:\n",
    "            highest_sensitivity = sensitivity\n",
    "            best_variant = modified_variant\n",
    "\n",
    "# Print the best modified variant with the highest sensitivity\n",
    "print(f\"The best modified variant with the highest sensitivity is: {best_variant} with sensitivity: {highest_sensitivity}\")\n"
   ]
  },
