     "output_type": "stream",
     "text": [
      "Sensitivity=TP/TP+FN: 0.72\n",
      "True Positives (TP): 35915\n",
      "False Negatives (FN): 13677\n",
      "Specificity=TN/TN+FP: 1.00\n",
      "True Negatives (TN): 46738\n",
      "False Positives (FP): 11\n"
     ]
    }
   ],
   "source": [
    "# Example usage:\n",
    "FASTA_file_1 = 'merged_output_N1.fasta'\n",
    "merged_fasta_file = 'merged_output_NA.fasta'\n",
    "FP = ['GRGARCCRTTCATMTCA']\n",
    "RP = ['AGTGCTTGYCATGATGGC']\n",
    "\n",
    "calculate_metrics(FASTA_file_1, FP, RP, merged_fasta_file)"
   ]
  },
