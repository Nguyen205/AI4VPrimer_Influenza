 "cells": [
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "f6b73bd4-7320-4f5e-8fac-beb0a4c2353a",
   "metadata": {},
   "outputs": [],
   "source": [
    "def calculate_metrics(fasta_file1, FP, RP, merged_fasta_file):\n",
    "    \"\"\"Calculate sensitivity and specificity using primer match results.\"\"\"\n",
    "    \n",
    "    # Load original FASTA 1\n",
    "    fasta_dict1 = {}\n",
    "    with open(fasta_file1, 'r') as f:\n",
    "        entry = False\n",
    "        for line in f:\n",
    "            if line.startswith('>'):\n",
    "                if entry:\n",
    "                    fasta_dict1[seq_name] = seq\n",
    "                seq_name = line.lstrip('>').rstrip('\\n')\n",
    "                seq = ''\n",
    "                entry = True\n",
    "            else:\n",
    "                seq += line.rstrip('\\n')\n",
    "        # Don't forget the last sequence\n",
    "        if entry:\n",
    "            fasta_dict1[seq_name] = seq\n",
    "\n",
    "    # Load merged FASTA file\n",
    "    merged_fasta_dict = {}\n",
    "    with open(merged_fasta_file, 'r') as f:\n",
    "        entry = False\n",
    "        for line in f:\n",
    "            if line.startswith('>'):\n",
    "                if entry:\n",
    "                    merged_fasta_dict[seq_name] = seq\n",
    "                seq_name = line.lstrip('>').rstrip('\\n')\n",
    "                seq = ''\n",
    "                entry = True\n",
    "            else:\n",
    "                seq += line.rstrip('\\n')\n",
    "        # Don't forget the last sequence\n",
    "        if entry:\n",
    "            merged_fasta_dict[seq_name] = seq\n",
    "\n",
    "    # Check for primer matches in fasta1 sequences\n",
    "    a = do_primers_work(FP, RP, fasta_dict1)\n",
    "\n",
    "    TP = 0  # True Positives\n",
    "    FN = 0  # False Negatives\n",
    "\n",
    "    for values in a.values():\n",
    "        if values.count(True) == 1:\n",
    "            TP += 1\n",
    "        else:\n",
    "            FN += 1\n",
    "\n",
    "    # Calculate sensitivity\n",
    "    sensitivity = TP / (TP + FN) if (TP + FN) > 0 else 0\n",
    "\n",
    "    # Now calculate overall matches using the same approach\n",
    "    overall_matches = 0\n",
    "    merged_results = do_primers_work(FP, RP, merged_fasta_dict)\n",
    "\n",
    "    for values in merged_results.values():\n",
    "        if True in values:\n",
    "            overall_matches += 1\n",
    "\n",
    "    # Calculate False Positives (FP)\n",
    "    FP_count = overall_matches - TP  # Overall matches in merged FASTA minus True Positives from fasta1\n",
    "\n",
    "    # Calculate True Negatives (TN)\n",
    "    TN = len(merged_fasta_dict) - overall_matches - FN  # Total in merged FASTA minus overall matches minus FN\n",
    "\n",
    "    # Calculate specificity\n",
    "    specificity = TN / (TN + FP_count) if (TN + FP_count) > 0 else 0\n",
    "\n",
    "    # Print results\n",
    "    print(f\"Sensitivity=TP/TP+FN: {sensitivity:.2f}\")\n",
    "    print(f\"True Positives (TP): {TP}\")\n",
    "    print(f\"False Negatives (FN): {FN}\")\n",
    "    print(f\"Specificity=TN/TN+FP: {specificity:.2f}\")\n",
    "    print(f\"True Negatives (TN): {TN}\")\n",
    "    print(f\"False Positives (FP): {FP_count}\")\n",
    "    "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "042a50ad-b3b4-4c1c-959e-5c459a8f95d5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def expand_degenerate_primer(primer):\n",
    "    \"\"\" Expand degenerate bases in a primer sequence. \"\"\"\n",
    "    def expand(base):\n",
    "        if base == 'A':\n",
    "            return ['A']\n",
    "        elif base == 'T':\n",
    "            return ['T']\n",
    "        elif base == 'G':\n",
    "            return ['G']\n",
    "        elif base == 'C':\n",
    "            return ['C']\n",
    "        elif base == 'R':\n",
    "            return ['A', 'G']\n",
    "        elif base == 'Y':\n",
    "            return ['C', 'T']\n",
    "        elif base == 'S':\n",
    "            return ['G', 'C']\n",
    "        elif base == 'W':\n",
    "            return ['A', 'T']\n",
    "        elif base == 'K':\n",
    "            return ['G', 'T']\n",
    "        elif base == 'M':\n",
    "            return ['A', 'C']\n",
    "        elif base == 'B':\n",
    "            return ['C', 'G', 'T']\n",
    "        elif base == 'D':\n",
    "            return ['A', 'G', 'T']\n",
    "        elif base == 'H':\n",
    "            return ['A', 'C', 'T']\n",
    "        elif base == 'V':\n",
    "            return ['A', 'C', 'G']\n",
    "        elif base == 'N':\n",
    "            return ['A', 'T', 'G', 'C']\n",
    "        else:\n",
    "            raise ValueError(f\"Unknown base '{base}' in primer sequence.\")\n",
    "    \n",
    "    expansions = ['']\n",
    "    for base in primer:\n",
    "        expanded_bases = expand(base)\n",
    "        new_expansions = []\n",
    "        for expansion in expansions:\n",
    "            for new_base in expanded_bases:\n",
    "                new_expansions.append(expansion + new_base)\n",
    "        expansions = new_expansions\n",
    "    \n",
    "    return expansions\n",
    "\n",
    "def comb(FP, RP):\n",
    "    comb_dict = {}\n",
    "    a = 0\n",
    "    for f in FP:\n",
    "        for r in RP:\n",
    "            a += 1\n",
    "            comb_dict[a] = [f, r]\n",
    "    return comb_dict\n",
    "\n",
    "def do_primers_work(FP, RP, fasta_dict):\n",
    "    \"\"\"Check for matches of forward and reverse primers in the provided FASTA dictionary.\"\"\"\n",
    "    D = comb(FP, RP)\n",
    "    variant_qPCR_results = {}\n",
    "    for seq_key in fasta_dict.keys():\n",
    "        variant_qPCR_results[seq_key] = []\n",
    "        \n",
    "        for x in D.keys():\n",
    "            forward_expanded = expand_degenerate_primer(D[x][0])\n",
    "            reverse_expanded = expand_degenerate_primer(D[x][1])\n",
    "            found_forward = any(fasta_dict[seq_key].count(target_seq) != 0 for target_seq in forward_expanded)\n",
    "            found_reverse = any(fasta_dict[seq_key].count(target_seq) != 0 for target_seq in reverse_expanded)\n",
    "            \n",
    "            if found_forward and found_reverse:\n",
    "                variant_qPCR_results[seq_key].append(True)\n",
    "            else:\n",
    "                variant_qPCR_results[seq_key].append(False)\n",
    "\n",
    "    return variant_qPCR_results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "f48fbdd9-2fc7-4b77-a981-0880bca41aa0",
