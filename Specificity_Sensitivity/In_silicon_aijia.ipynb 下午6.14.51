   "source": [
    "FP = ['GACACAGTACTWGARAAGAATG']\n",
    "RP = ['']\n",
    "a = do_primers_work(FP,RP,FASTA_dict)\n",
    "\n",
    "T = 0\n",
    "F = 0\n",
    "for values in a.values():\n",
    "    if values.count(True) == 1:\n",
    "        T += 1\n",
    "    else:\n",
    "        F += 1\n",
    "print(\"sensitivity of primer pairs in all H1N1:\",T/(T+F))\n",
    "\n"
   ]
