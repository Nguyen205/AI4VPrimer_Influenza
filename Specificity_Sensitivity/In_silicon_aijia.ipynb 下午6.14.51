   "source": [
    "def comb(FP, RP):\n",
    "    comb_dict = {}\n",
    "    a = 0\n",
    "    for f in FP:\n",
    "        for r in RP:\n",
    "            a += 1\n",
    "            comb_dict[a] = [f, r]\n",
    "    return comb_dict\n",
    "\n",
    "def expand_degenerate_primer(primer):\n",
    "    \"\"\" Expand degenerate bases in a primer sequence \"\"\"\n",
    "    def expand(base):\n",
    "        if base == 'A':\n",
    "            return ['A']\n",
    "        elif base == 'T':\n",
    "            return ['T']\n",
    "        elif base == 'G':\n",
    "            return ['G']\n",
    "        elif base == 'C':\n",
    "            return ['C']\n",
    "        elif base == 'R':\n",
    "            return ['A', 'G']\n",
    "        elif base == 'Y':\n",
    "            return ['C', 'T']\n",
    "        elif base == 'S':\n",
    "            return ['G', 'C']\n",
    "        elif base == 'W':\n",
    "            return ['A', 'T']\n",
    "        elif base == 'K':\n",
    "            return ['G', 'T']\n",
    "        elif base == 'M':\n",
    "            return ['A', 'C']\n",
    "        elif base == 'B':\n",
    "            return ['C', 'G', 'T']\n",
    "        elif base == 'D':\n",
    "            return ['A', 'G', 'T']\n",
    "        elif base == 'H':\n",
    "            return ['A', 'C', 'T']\n",
    "        elif base == 'V':\n",
    "            return ['A', 'C', 'G']\n",
    "        elif base == 'N':\n",
    "            return ['A', 'T', 'G', 'C']\n",
    "        else:\n",
    "            raise ValueError(f\"Unknown base '{base}' in primer sequence.\")\n",
    "    \n",
    "    expansions = ['']\n",
    "    for base in primer:\n",
    "        expanded_bases = expand(base)\n",
    "        new_expansions = []\n",
    "        for expansion in expansions:\n",
    "            for new_base in expanded_bases:\n",
    "                new_expansions.append(expansion + new_base)\n",
    "        expansions = new_expansions\n",
    "    \n",
    "    return expansions\n",
    "\n",
    "def do_primers_work(FP, RP, fasta_dict):\n",
    "    # Generate combinations of FP and RP\n",
    "    D = comb(FP, RP)\n",
    "    variant_qPCR_results = {}\n",
    "    for seq_key in fasta_dict.keys():\n",
    "        variant_qPCR_results[seq_key] = []\n",
    "        \n",
    "        for x in D.keys():\n",
    "            forward_expanded = expand_degenerate_primer(D[x][0])\n",
    "            reverse_expanded = expand_degenerate_primer(D[x][1])\n",
    "            found_forward = any(fasta_dict[seq_key].count(target_seq) != 0 for target_seq in forward_expanded)\n",
    "            found_reverse = any(fasta_dict[seq_key].count(target_seq) != 0 for target_seq in reverse_expanded)\n",
    "            \n",
    "            if found_forward and found_reverse:\n",
    "                variant_qPCR_results[seq_key].append(True)\n",
    "            else:\n",
    "                variant_qPCR_results[seq_key].append(False)\n",
    "\n",
    "    return variant_qPCR_results"
   ]
  },
  {
   "cell_type": "code",
