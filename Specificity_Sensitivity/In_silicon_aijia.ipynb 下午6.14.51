   "source": [
    "def expand_degenerate_primer(primer):\n",
    "    \"\"\" Expand degenerate bases in a primer sequence \"\"\"\n",
    "    def expand(base):\n",
    "        if base == 'A':\n",
    "            return ['A', 'N']\n",
    "        elif base == 'T':\n",
    "            return ['T', 'N']\n",
    "        elif base == 'G':\n",
    "            return ['G', 'N']\n",
    "        elif base == 'C':\n",
    "            return ['C', 'N']\n",
    "        elif base == 'R':\n",
    "            return ['A', 'G', 'N']\n",
    "        elif base == 'Y':\n",
    "            return ['C', 'T', 'N']\n",
    "        elif base == 'S':\n",
    "            return ['G', 'C', 'N']\n",
    "        elif base == 'W':\n",
    "            return ['A', 'T', 'N']\n",
    "        elif base == 'K':\n",
    "            return ['G', 'T', 'N']\n",
    "        elif base == 'M':\n",
    "            return ['A', 'C', 'N']\n",
    "        elif base == 'B':\n",
    "            return ['C', 'G', 'T', 'N']\n",
    "        elif base == 'D':\n",
    "            return ['A', 'G', 'T', 'N']\n",
    "        elif base == 'H':\n",
    "            return ['A', 'C', 'T', 'N']\n",
    "        elif base == 'V':\n",
    "            return ['A', 'C', 'G', 'N']\n",
    "        elif base == 'N':\n",
    "            return ['A', 'T', 'G', 'C']  # 'N' remains as is\n",
    "        else:\n",
    "            raise ValueError(f\"Unknown base '{base}' in primer sequence.\")\n",
    "    \n",
    "    variants = []\n",
    "    for i in range(len(primer)):\n",
    "        base = primer[i]\n",
    "        expanded_bases = expand(base)\n",
    "        for new_base in expanded_bases:\n",
    "            variant = primer[:i] + new_base + primer[i+1:]\n",
    "            variants.append(variant)\n",
    "    \n",
    "    return variants\n",
    "\n",
    "def do_primers_work(FP):\n",
    "    variant_qPCR_results = {}\n",
    "    for seq_key in FASTA_dict.keys():\n",
    "        variant_qPCR_results[seq_key] = []\n",
    "        \n",
    "        for target_seq1 in FP:\n",
    "            expanded_primers = expand_degenerate_primer(target_seq1)\n",
    "            found = False\n",
    "            for expanded_primer in expanded_primers:\n",
    "                if FASTA_dict[seq_key].count(expanded_primer) != 0:\n",
    "                    found = True\n",
    "                    break\n",
    "            if found:\n",
    "                break\n",
    "        \n",
    "        variant_qPCR_results[seq_key].append(found)\n",
    "    \n",
    "    return variant_qPCR_results\n",
    "\n",
    "# Example FASTA file reading and processing\n",
    "FASTA_file = 'H1N1 SEG7.fasta'\n",
    "FASTA_dict = {}\n",
    "\n",
    "with open(FASTA_file, 'r') as f:\n",
    "    seq_name = None\n",
    "    seq = ''\n",
    "    for line in f:\n",
    "        if line.startswith('>'):\n",
    "            if seq_name is not None:\n",
    "                FASTA_dict[seq_name] = seq\n",
    "            seq_name = line.lstrip('>').rstrip('\\n')\n",
    "            seq = ''\n",
    "        else:\n",
    "            seq += line.rstrip('\\n')\n",
    "    # Add last sequence after loop\n",
    "    if seq_name is not None:\n",
    "        FASTA_dict[seq_name] = seq\n",
    "\n",
    "# Example FP list with degenerate primer\n",
    "FP = ['GGATTTGTGTTCACGCTCAC']\n",
    "# Generate and run the function for each variant with 'N' substitutions\n",
    "for variant in expand_degenerate_primer(FP[0]):\n",
    "    print(f\"Running for variant: {variant}\")\n",
    "    result = do_primers_work([variant])\n",
    "    \n",
    "    # Count the True and False results\n",
    "    T = sum(1 for values in result.values() if values[0])\n",
    "    F = sum(1 for values in result.values() if not values[0])\n",
    "    \n",
    "    print(\"Sensitivity:\", T / (T + F))\n",
    "    print(\"Number of sequences with the primer present (True):\", T)\n",
    "    print(\"Number of sequences without the primer (False):\", F)\n",
    "    print(\"--------------------\")"
   ]
  },
